# backend/Dockerfile.dev  ─  Development only (hot reload)
FROM node:22-bookworm-slim

WORKDIR /app

# Install OpenSSL (required by Prisma)
RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

# Copy package files and install ALL deps (including devDependencies)
COPY package.json package-lock.json ./
COPY prisma ./prisma
RUN npm install

# Generate Prisma client
RUN npx prisma generate

# Source code is mounted as a volume at runtime — no COPY . . needed here

EXPOSE 4000

# Run Prisma migrations then start in watch mode
CMD ["sh", "-c", "npx prisma migrate deploy && npm run start:dev"]
