# frontend/Dockerfile.dev  ─  Development only (Next.js Fast Refresh)
FROM node:22-alpine

WORKDIR /app

# Install compatibility lib (required on Alpine)
RUN apk add --no-cache libc6-compat

# Copy package files and install ALL deps
COPY package.json package-lock.json ./
RUN npm install

# Source code is mounted as a volume at runtime — no COPY . . needed here

EXPOSE 3000

CMD ["npm", "run", "dev"]
